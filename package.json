{
  "name": "@truenas/mcp-base",
  "version": "0.0.0",
  "description": "Shared core library for TrueNAS MCP: tool catalog, system registry, safety model, multi-system fan-out",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "yarn build",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spec.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "smoke": "tsx scripts/smoke.ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@truenas/api-client": "^1.0.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@truenas/api-client": "^1.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "rxjs": "~7.8.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.10.3",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truenas/truenas-mcp-base.git"
  },
  "keywords": [
    "truenas",
    "mcp",
    "model-context-protocol"
  ]
}
